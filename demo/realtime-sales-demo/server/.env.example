# =============================================================================
# SECRETS TEMPLATE — copy this file to ".env" in this same folder (server/)
# =============================================================================
# Local: server/.env  |  Production: Vercel → Settings → Environment Variables
# Full go-live list: repo root GO-LIVE-VERCEL.md
# =============================================================================



# Get a key: https://platform.openai.com/account/api-keys



# Use: OPENAI_API_KEY=sk-...  (no quotes; no spaces around =)



# The demo API prefers this file over Windows user/system OPENAI_API_KEY.



# GET http://127.0.0.1:8780/api/debug/openai_key_fingerprint — shows length/last4 (local testing).



OPENAI_API_KEY=sk-proj-your-key-here

# --- ElevenLabs Conversational AI (voice quality upgrade) ---
# ElevenLabs handles STT + TTS; GPT-4o (via OPENAI_API_KEY above) handles reasoning + tools.
# Setup steps:
#   1. Create an agent at https://elevenlabs.io/app/conversational-ai
#   2. Set LLM -> Custom LLM, URL: https://<your-server>/api/elevenlabs/llm
#   3. Pick a voice (e.g. Adam, Josh, Antoni) and configure first message / greeting
#   4. Copy the Agent ID from the agent settings page
#   5. Add your ElevenLabs API key from https://elevenlabs.io/app/settings/api-keys
# The browser calls GET /api/elevenlabs/token -> signed WebSocket URL -> ElevenLabs session.
# For phone calls: in the ElevenLabs agent settings, enable Phone -> import Twilio creds.

ELEVENLABS_API_KEY=sk_...your_elevenlabs_api_key...
ELEVENLABS_AGENT_ID=agent_...your_agent_id...
# Optional: override the GPT model used for the ElevenLabs custom LLM endpoint
# ELEVENLABS_CHAT_MODEL=gpt-4o-mini
#
# --- Post-call webhook HMAC secret (optional but recommended) ---
# In ElevenLabs dashboard → Agents → Settings → Post-call webhook, after adding the URL,
# copy the generated "Signing secret" and paste it here.  If set, every incoming webhook
# request has its HMAC-SHA256 signature verified before processing.
# ELEVENLABS_WEBHOOK_SECRET=whsec_...

# --- Phone voice (ElevenLabs SIP — same voice as browser demo) ---
# Set ELEVENLABS_SIP_URI to route phone calls through ElevenLabs instead of OpenAI Realtime.
# This gives the same high-quality ElevenLabs voice on phone calls as the browser demo.
#
# Setup (one-time dashboard steps):
#   1. ElevenLabs → Agents → Phone Numbers → "Import from SIP trunk"
#      - Phone Number: your Hammer number in E.164 (e.g. +15128831336)
#      - Outbound Address: your Twilio Elastic SIP Trunk termination hostname
#      - Assign Agent: select the existing Hammer agent
#   2. Twilio → Elastic SIP Trunks → your trunk → Origination
#      - Change URI from sip:proj_xxx@sip.api.openai.com to sip:+1XXXXXXXXXX@sip.rtc.elevenlabs.io:5060
#
# Once both dashboard steps are done, set this var and redeploy Fly.io:
# ELEVENLABS_SIP_URI=sip:+1XXXXXXXXXX@sip.rtc.elevenlabs.io:5060
#
# --- Phone voice (OpenAI Realtime SIP — legacy fallback) ---
# Used automatically when ELEVENLABS_SIP_URI is NOT set.
# OPENAI_PROJECT_ID=proj_xxxxxxxx   # Same proj_ as Twilio SIP origination URI + OpenAI webhook project
# OPENAI_WEBHOOK_SECRET=whsec_...
# REALTIME_SALES_TELEPHONY=1
# DEMO_PHONE_NUMBER=+1XXXXXXXXXX      # Must be the Twilio number on the SIP trunk (E.164)
# DEMO_PHONE_DISPLAY=(XXX) XXX-XXXX
# Outbound "Call me" (Twilio REST → SIP on answer) — Fly telephony host only:
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_OUTBOUND_ENABLED=1
# TELEPHONY_PUBLIC_BASE_URL=https://hammer-voice-telephony.fly.dev
# TWILIO_OUTBOUND_ALLOWLIST=+15551234567   # optional dev/staging restrict destinations
# REALTIME_SALES_CORS_ORIGINS=https://www.hammertime.com,https://hammer-finalsite.vercel.app,http://127.0.0.1:5173

# Glass chat (`POST /api/chat`) — default is GPT-5.5; override if needed.

# REALTIME_SALES_CHAT_MODEL=gpt-5.5

# --- Realtime voice profile (Hammer demo — locked TTS in code) ---
# Model (browser + SIP + WebRTC accept):
# REALTIME_SALES_MODEL=gpt-realtime-2
# TTS output is NOT env-configurable — always shimmer @ speed 1.0:
#   server/realtime_voice_config.py  +  web/src/realtime-voice.ts
# Do not set REALTIME_SALES_VOICE or VITE_REALTIME_VOICE (ignored; prevents reconnect drift).
# Reasoning + VAD (match production demo):
# REALTIME_SALES_SIP_REASONING_MINIMAL=1
# Phone PSTN default: medium (reduces false interrupts / choppy audio vs browser high)
# REALTIME_SALES_SIP_VAD_EAGERNESS=medium
# Fallback settle if session.updated is slow (seconds, default 0.4):
# REALTIME_SALES_SIP_FIRST_TTS_SETTLE_S=0.4
# Browser: reasoning minimal + semantic_vad eagerness high unless VITE_REALTIME_PLAYGROUND_PARITY=1

# Voice latency — wiki retrieval (defaults: TOP_K=6, TOOL_MAX_CHARS=4500)
# REALTIME_SALES_TOP_K=6
# REALTIME_SALES_TOOL_MAX_CHARS=4500
# Max seconds to keep opening VAD locked if playback-end event is missed (default 18)
# REALTIME_SALES_SIP_OPENING_GUARD_S=18
# Max seconds to keep opening VAD locked if playback-end event is missed (default 18)
# REALTIME_SALES_SIP_OPENING_GUARD_S=18



# --- Zapier (voice signup emails + "I approve" confirmation) ---

# Voice AI only (capture_lead / agreement email). Filter Zap on event = agreement_email_request.
# Production Catch Hook (voice capture_lead → agreement email):
# https://hooks.zapier.com/hooks/catch/27649081/4od2z1k/

ZAPIER_LEAD_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/27649081/4od2z1k/

# --- Zapier (website “Get started” lead form only — separate Catch Hook) ---

# Do not reuse ZAPIER_LEAD_WEBHOOK_URL (voice / capture_lead / agreement email).
# Website modal POSTs channel=website, event=website_lead here only.
# https://hooks.zapier.com/hooks/catch/27649081/4o1aob8/

ZAPIER_WEBSITE_LEAD_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/27649081/4o1aob8/

# --- Zapier (end-of-call voice summary → Slack) ---
# Separate Catch Hook. Fires when a voice call ends with contact info (email, phone, name, dealership, or agreement sent).
# Filter Zap on event = voice_call_summary. Setup: server/zapier/VOICE_CALL_SUMMARY_SLACK.md
# ZAPIER_VOICE_CALL_SUMMARY_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/XXXXXXXX/yyyyyyy/

# Local dev (Vite :5173 proxies /api → uvicorn :8780). Emails use HTML HAMMER AI banner by default.
REALTIME_SALES_PUBLIC_BASE_URL=http://127.0.0.1:8780
# Optional UI origin (not used for email logo path):
# REALTIME_SALES_SITE_URL=http://127.0.0.1:5173
# Preview PNG in agreement HTML on your machine only (Gmail via Zapier still cannot load localhost):
# HAMMER_EMAIL_LOGO_USE_IMAGE=1
# HAMMER_AGREEMENT_LOGO_URL=http://127.0.0.1:8780/email/hammer-ai-logo.png



# Zap 2: Gmail "I approve" → POST https://YOUR-HOST/api/zapier/approval

# Header: X-Zapier-Secret: <same value as below>

ZAPIER_APPROVAL_CALLBACK_SECRET=

# Persistent store for I approve replies (default: server/.data/agreement_approvals.json)
# REALTIME_SALES_APPROVALS_PATH=

# How long check_agreement_approval polls when visitor says they just replied (Gmail→Zap 2 lag)
# AGREEMENT_APPROVAL_JUST_REPLIED_WAIT_SECONDS=12
# AGREEMENT_APPROVAL_POLL_MAX_SECONDS=20
# AGREEMENT_APPROVAL_POLL_INTERVAL_SECONDS=1.0



# --- Google Calendar (rep walkthrough bookings) ---
# Uses the same inbox that sends Hammer agreement emails (Zapier/Gmail).
# Setup:
#   1. Enable Google Calendar API in Google Cloud Console
#   2. Create a service account and download JSON credentials
#   3. Share hannah@hammer-corp.com (or your agreement sender) with the service account
#      — grant "Make changes to events"
#   4. Paste the full JSON below OR set GOOGLE_APPLICATION_CREDENTIALS to the file path
#
# HAMMER_AGREEMENT_SENDER_EMAIL=hannah@hammer-corp.com
# GOOGLE_CALENDAR_CREDENTIALS_JSON={"type":"service_account",...}
# GOOGLE_CALENDAR_TIMEZONE=America/Chicago
# GOOGLE_CALENDAR_APPT_DURATION_MINUTES=30
# Optional Workspace domain-wide delegation (impersonate the agreement sender):
# GOOGLE_CALENDAR_DELEGATED_USER=hannah@hammer-corp.com

# --- Hammer Office account creation (PHASE B after I approve) ---

# Staff login used to open https://office.hammer-corp.com/accounts/new

HAMMER_OFFICE_EMAIL=

HAMMER_OFFICE_PASSWORD=

# HAMMER_OFFICE_BASE_URL=https://office.hammer-corp.com

# HAMMER_OFFICE_DRY_RUN=1

# HAMMER_OFFICE_USE_PLAYWRIGHT=1
# HAMMER_OFFICE_INSTANT=1
# Instant mode (default): voice tools return immediately; browser fills in background.
# Set HAMMER_OFFICE_INSTANT=0 to block on each open/fill (slower, easier to debug).

# Production / Vercel / Fly: always headless (no Chromium window). Enforced in code when deployed.
HAMMER_OFFICE_HEADLESS=1

# Local only — watch Chromium fill the form (never set on Vercel):
# Easiest: run .\4-START-ACCOUNT-DEBUG.ps1 (sets HAMMER_OFFICE_DEBUG=1 automatically).
# HAMMER_OFFICE_DEBUG=1
# HAMMER_OFFICE_ALLOW_VISIBLE_BROWSER=1
# HAMMER_OFFICE_HEADLESS=0
# HAMMER_OFFICE_INSTANT=0
# HAMMER_OFFICE_SLOW_MO=400
# HAMMER_OFFICE_KEEP_OPEN=300
# HAMMER_OFFICE_KEEP_OPEN_AFTER_SUBMIT=1
# Debug panel: http://127.0.0.1:8780/debug/hammer-account (see LOCAL_ACCOUNT_DEBUG.md)

# --- OpenAI Ads conversion tracking (page views + form submissions) ---
# Both values come from OpenAI Ads Manager -> Conversions tab
# (NOT Settings -> API Keys - that key type lacks the required scope).
# Browser tracker: web/public/openai-tracker.js  ->  POST /api/track  ->  OpenAI
# OPENAI_ADS_PIXEL_ID=
# OPENAI_ADS_CONVERSIONS_API_KEY=sk-svcacct-...
# Set true while testing: OpenAI validates events without counting conversions.
# OPENAI_ADS_VALIDATE_ONLY=true

# --- Voice admin dashboard (production + optional local) ---
# Long random password — only you should know this. Required for /admin/voice on the live site.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# REALTIME_SALES_ADMIN_SECRET=your-password-here
# Live dashboard URL: https://YOUR-DOMAIN/admin/voice
# Local (no password): http://127.0.0.1:8780/debug/voice-dashboard



# --- Phone call disclosure (Twilio <Say> plays before AI connects on every inbound + outbound call) ---
# Twilio reads this aloud at call start using Polly.Joanna (US English).
# Have counsel review wording for your target states before going live.
# Set VOICE_PHONE_DISCLOSURE_ENABLED=0 to skip playback (text is kept for when you re-enable).
VOICE_PHONE_DISCLOSURE_ENABLED=1
VOICE_PHONE_DISCLOSURE=This call is from Hammer. It may be recorded and uses an artificial intelligence voice assistant.
# Optional: use a pre-rendered WAV/MP3 disclosure instead of Twilio TTS for more consistent call-start latency.
# VOICE_PHONE_DISCLOSURE_AUDIO_URL=https://your-cdn.example.com/hammer-phone-disclosure.mp3

# Inbound Twilio setup — set your demo number's Voice URL in Twilio Console:
#   Phone Numbers → your number → "A call comes in"
#   Webhook  POST  https://<your-fly-app>.fly.dev/api/twilio/voice/inbound-connect
# This plays the disclosure then bridges to OpenAI SIP (same as outbound).



# --- Production (Vercel) — NEVER commit real values; use Project → Settings → Environment Variables ---
#
# Required on live site:
#   OPENAI_API_KEY
#   ZAPIER_LEAD_WEBHOOK_URL          (voice / agreement email)
#   ZAPIER_WEBSITE_LEAD_WEBHOOK_URL  (website signup form)
#   ZAPIER_APPROVAL_CALLBACK_SECRET  (long random string; Zap 2 sends X-Zapier-Secret)
#   HAMMER_OFFICE_EMAIL / HAMMER_OFFICE_PASSWORD  (server-only; never VITE_*)
#   REALTIME_SALES_PUBLIC_BASE_URL=https://your-production-domain.com
#
# NEVER put secrets in VITE_* vars — those are baked into the public JS bundle.
# Debug routes (/api/debug/*) are disabled automatically on Vercel (REALTIME_SALES_SERVERLESS=1).
#
# Public UI flags (Vercel production for hammer-finalsite):
#   VITE_ENABLE_BROWSER_VOICE=0   (default — phone pill CTA; set 1 for browser WebRTC primary CTA)
#   VITE_ENABLE_CHAT=1            (default on; set 0 to hide chat bubble)
#   VITE_ELEVENLABS_TOKEN_PREFETCH=1 (default — prefetch conversation token on hover/pointerdown/focus)
#   VITE_VOICE_LATENCY_DEBUG=0    (set 1 to log browser voice latency marks)

# Optional: REALTIME_SALES_CORS_ORIGINS=https://your-custom-domain.com



# UI strings load from wiki/demo-public-site-copy.md via GET /api/site_copy.

# If this points at another repo (e.g. VibeVoice), edits under Hammer-Sell-me-a-pen-challenge/wiki

# will not show in the browser. Comment out or remove to use run-demo.ps1 / auto-detect:

# REALTIME_SALES_REPO_ROOT=C:\path\to\Hammer-Sell-me-a-pen-challenge

# REALTIME_SALES_WIKI_DIR=C:\path\to\Hammer-Sell-me-a-pen-challenge\wiki


