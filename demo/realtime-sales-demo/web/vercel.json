{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm ci --include=dev",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/(reviews|faq|terms|privacy|support|about)",
      "destination": "/$1/index.html"
    },
    { "source": "/(reviews|faq|terms|privacy|support|about)/", "destination": "/$1/index.html" },
    { "source": "/get-started", "destination": "/index.html" }
  ]
}
